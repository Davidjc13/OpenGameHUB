<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:OpenGameHUB.ViewModels"
             xmlns:conv="using:OpenGameHUB.Converters"
             x:Class="OpenGameHUB.Controls.GameGridCard"
             x:DataType="vm:GameItemViewModel">
    <UserControl.Resources>
        <conv:PlatformBrushConverter x:Key="PlatformBrushConverter"/>
    </UserControl.Resources>

    <Border Classes="game-card game-card-grid"
            BorderBrush="{Binding IsSelected, Converter={x:Static conv:SelectionBorderConverter.Instance}}"
            PointerPressed="OnCardPressed"
            DoubleTapped="OnGameDoubleTapped">
        <Grid RowDefinitions="270,Auto,Auto,Auto">
            <Border Grid.Row="0"
                    Classes="game-cover-area">
                <Panel>
                    <Panel IsVisible="{Binding DisplayGridCover}">
                        <Image Source="{Binding CoverImage}"
                               Stretch="Uniform"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"
                               Opacity="{Binding GridCoverOpacity}"/>
                        <Border Classes="overlay-dim"
                                IsVisible="{Binding !IsInstalled}"/>
                    </Panel>
                    <Border IsVisible="{Binding !DisplayGridCover}"
                            Background="{Binding Platform, Converter={StaticResource PlatformBrushConverter}}"
                            Opacity="{Binding GridPlaceholderOpacity}"/>
                    <TextBlock Text="{Binding Title}"
                               IsVisible="{Binding !DisplayGridCover}"
                               Margin="14"
                               VerticalAlignment="Center"
                               HorizontalAlignment="Center"
                               TextAlignment="Center"
                               TextWrapping="Wrap"
                               Classes="card-title"
                               MaxHeight="72"/>
                </Panel>
            </Border>

            <StackPanel Grid.Row="1" Margin="10,8,10,0" Spacing="3">
                <Border Classes="platform-badge"
                        Background="{Binding Platform, Converter={StaticResource PlatformBrushConverter}}">
                    <TextBlock Text="{Binding PlatformLabel}"
                               Classes="badge-label"/>
                </Border>
                <TextBlock Text="{Binding Title}"
                           Classes="card-title"
                           TextWrapping="Wrap"
                           MaxHeight="36"
                           TextTrimming="CharacterEllipsis"/>
            </StackPanel>

            <TextBlock Grid.Row="2"
                       Margin="10,2,10,0"
                       Text="{Binding InstallStatus}"
                       FontSize="11"
                       Classes="text-status"/>

            <Button Grid.Row="3"
                    Margin="10,8,10,10"
                    Classes="primary"
                    HorizontalAlignment="Stretch"
                    Content="{Binding ActionLabel}"
                    Click="OnPlayClick"/>
        </Grid>
    </Border>
</UserControl>
