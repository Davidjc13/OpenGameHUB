<Styles xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Style Selector="Border.game-card">
        <Setter Property="CornerRadius" Value="{StaticResource RadiusCard}"/>
        <Setter Property="BorderThickness" Value="2"/>
        <Setter Property="Background" Value="{DynamicResource BrushBgCard}"/>
        <Setter Property="ClipToBounds" Value="True"/>
    </Style>

    <Style Selector="Border.game-card-grid">
        <Setter Property="Margin" Value="6"/>
        <Setter Property="HorizontalAlignment" Value="Stretch"/>
        <Setter Property="VerticalAlignment" Value="Stretch"/>
        <Setter Property="MinWidth" Value="136"/>
    </Style>

    <Style Selector="Border.platform-badge">
        <Setter Property="CornerRadius" Value="{StaticResource RadiusBadge}"/>
        <Setter Property="Padding" Value="5,2"/>
        <Setter Property="HorizontalAlignment" Value="Left"/>
    </Style>

    <Style Selector="Border.game-cover-area">
        <Setter Property="Background" Value="{DynamicResource BrushBgCover}"/>
        <Setter Property="ClipToBounds" Value="True"/>
    </Style>

    <Style Selector="Border.game-list-thumb">
        <Setter Property="Width" Value="48"/>
        <Setter Property="Height" Value="72"/>
        <Setter Property="CornerRadius" Value="{StaticResource RadiusCover}"/>
        <Setter Property="ClipToBounds" Value="True"/>
        <Setter Property="Background" Value="{DynamicResource BrushBgCover}"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
    </Style>

</Styles>
