<ResourceDictionary xmlns="https://github.com/avaloniaui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <ResourceDictionary.ThemeDictionaries>
        <ResourceDictionary x:Key="Dark">
            <Color x:Key="ColorBgApp">#10131A</Color>
            <Color x:Key="ColorBgPanel">#161B27</Color>
            <Color x:Key="ColorBgCard">#1E2535</Color>
            <Color x:Key="ColorBgCover">#141A28</Color>
            <Color x:Key="ColorBgInput">#1A2030</Color>
            <Color x:Key="ColorBgBanner">#1A2438</Color>
            <Color x:Key="ColorBgDevPanel">#1A1218</Color>

            <Color x:Key="ColorBorder">#2B3448</Color>
            <Color x:Key="ColorBorderBanner">#3D6FB8</Color>
            <Color x:Key="ColorBorderDev">#5C3040</Color>

            <Color x:Key="ColorAccent">#3D6AF2</Color>
            <Color x:Key="ColorAccentHover">#4F7BFF</Color>

            <Color x:Key="ColorTextPrimary">#F4F7FF</Color>
            <Color x:Key="ColorTextSecondary">#9AA6BF</Color>
            <Color x:Key="ColorTextTertiary">#7E8AA3</Color>
            <Color x:Key="ColorTextMuted">#6B7A96</Color>
            <Color x:Key="ColorTextLabel">#D7DFF1</Color>
            <Color x:Key="ColorTextSidebar">#C5CEE0</Color>
            <Color x:Key="ColorTextStatus">#8B97B0</Color>
            <Color x:Key="ColorTextBanner">#E8F0FF</Color>
            <Color x:Key="ColorTextDev">#F2B8C6</Color>

            <Color x:Key="ColorOverlayDim">#66484848</Color>

            <SolidColorBrush x:Key="BrushBgApp" Color="{StaticResource ColorBgApp}"/>
            <SolidColorBrush x:Key="BrushBgPanel" Color="{StaticResource ColorBgPanel}"/>
            <SolidColorBrush x:Key="BrushBgCard" Color="{StaticResource ColorBgCard}"/>
            <SolidColorBrush x:Key="BrushBgCover" Color="{StaticResource ColorBgCover}"/>
            <SolidColorBrush x:Key="BrushBgInput" Color="{StaticResource ColorBgInput}"/>
            <SolidColorBrush x:Key="BrushBgBanner" Color="{StaticResource ColorBgBanner}"/>
            <SolidColorBrush x:Key="BrushBgDevPanel" Color="{StaticResource ColorBgDevPanel}"/>

            <SolidColorBrush x:Key="BrushBorder" Color="{StaticResource ColorBorder}"/>
            <SolidColorBrush x:Key="BrushBorderBanner" Color="{StaticResource ColorBorderBanner}"/>
            <SolidColorBrush x:Key="BrushBorderDev" Color="{StaticResource ColorBorderDev}"/>

            <SolidColorBrush x:Key="BrushAccent" Color="{StaticResource ColorAccent}"/>
            <SolidColorBrush x:Key="BrushAccentHover" Color="{StaticResource ColorAccentHover}"/>

            <SolidColorBrush x:Key="BrushTextPrimary" Color="{StaticResource ColorTextPrimary}"/>
            <SolidColorBrush x:Key="BrushTextSecondary" Color="{StaticResource ColorTextSecondary}"/>
            <SolidColorBrush x:Key="BrushTextTertiary" Color="{StaticResource ColorTextTertiary}"/>
            <SolidColorBrush x:Key="BrushTextMuted" Color="{StaticResource ColorTextMuted}"/>
            <SolidColorBrush x:Key="BrushTextLabel" Color="{StaticResource ColorTextLabel}"/>
            <SolidColorBrush x:Key="BrushTextSidebar" Color="{StaticResource ColorTextSidebar}"/>
            <SolidColorBrush x:Key="BrushTextStatus" Color="{StaticResource ColorTextStatus}"/>
            <SolidColorBrush x:Key="BrushTextBanner" Color="{StaticResource ColorTextBanner}"/>
            <SolidColorBrush x:Key="BrushTextDev" Color="{StaticResource ColorTextDev}"/>

            <SolidColorBrush x:Key="BrushOverlayDim" Color="{StaticResource ColorOverlayDim}"/>
        </ResourceDictionary>

        <ResourceDictionary x:Key="Light">
            <Color x:Key="ColorBgApp">#E8ECF4</Color>
            <Color x:Key="ColorBgPanel">#F7F9FC</Color>
            <Color x:Key="ColorBgCard">#FFFFFF</Color>
            <Color x:Key="ColorBgCover">#DDE3EF</Color>
            <Color x:Key="ColorBgInput">#FFFFFF</Color>
            <Color x:Key="ColorBgBanner">#E4ECFA</Color>
            <Color x:Key="ColorBgDevPanel">#F8EBEF</Color>

            <Color x:Key="ColorBorder">#C5CEDD</Color>
            <Color x:Key="ColorBorderBanner">#3D6FB8</Color>
            <Color x:Key="ColorBorderDev">#C87888</Color>

            <Color x:Key="ColorAccent">#3D6AF2</Color>
            <Color x:Key="ColorAccentHover">#2F5AE0</Color>

            <Color x:Key="ColorTextPrimary">#161C28</Color>
            <Color x:Key="ColorTextSecondary">#5A667C</Color>
            <Color x:Key="ColorTextTertiary">#6B778C</Color>
            <Color x:Key="ColorTextMuted">#8A95A8</Color>
            <Color x:Key="ColorTextLabel">#2A3448</Color>
            <Color x:Key="ColorTextSidebar">#3A4558</Color>
            <Color x:Key="ColorTextStatus">#5A667C</Color>
            <Color x:Key="ColorTextBanner">#1A2A44</Color>
            <Color x:Key="ColorTextDev">#8B3040</Color>

            <Color x:Key="ColorOverlayDim">#55000000</Color>

            <SolidColorBrush x:Key="BrushBgApp" Color="{StaticResource ColorBgApp}"/>
            <SolidColorBrush x:Key="BrushBgPanel" Color="{StaticResource ColorBgPanel}"/>
            <SolidColorBrush x:Key="BrushBgCard" Color="{StaticResource ColorBgCard}"/>
            <SolidColorBrush x:Key="BrushBgCover" Color="{StaticResource ColorBgCover}"/>
            <SolidColorBrush x:Key="BrushBgInput" Color="{StaticResource ColorBgInput}"/>
            <SolidColorBrush x:Key="BrushBgBanner" Color="{StaticResource ColorBgBanner}"/>
            <SolidColorBrush x:Key="BrushBgDevPanel" Color="{StaticResource ColorBgDevPanel}"/>

            <SolidColorBrush x:Key="BrushBorder" Color="{StaticResource ColorBorder}"/>
            <SolidColorBrush x:Key="BrushBorderBanner" Color="{StaticResource ColorBorderBanner}"/>
            <SolidColorBrush x:Key="BrushBorderDev" Color="{StaticResource ColorBorderDev}"/>

            <SolidColorBrush x:Key="BrushAccent" Color="{StaticResource ColorAccent}"/>
            <SolidColorBrush x:Key="BrushAccentHover" Color="{StaticResource ColorAccentHover}"/>

            <SolidColorBrush x:Key="BrushTextPrimary" Color="{StaticResource ColorTextPrimary}"/>
            <SolidColorBrush x:Key="BrushTextSecondary" Color="{StaticResource ColorTextSecondary}"/>
            <SolidColorBrush x:Key="BrushTextTertiary" Color="{StaticResource ColorTextTertiary}"/>
            <SolidColorBrush x:Key="BrushTextMuted" Color="{StaticResource ColorTextMuted}"/>
            <SolidColorBrush x:Key="BrushTextLabel" Color="{StaticResource ColorTextLabel}"/>
            <SolidColorBrush x:Key="BrushTextSidebar" Color="{StaticResource ColorTextSidebar}"/>
            <SolidColorBrush x:Key="BrushTextStatus" Color="{StaticResource ColorTextStatus}"/>
            <SolidColorBrush x:Key="BrushTextBanner" Color="{StaticResource ColorTextBanner}"/>
            <SolidColorBrush x:Key="BrushTextDev" Color="{StaticResource ColorTextDev}"/>

            <SolidColorBrush x:Key="BrushOverlayDim" Color="{StaticResource ColorOverlayDim}"/>
        </ResourceDictionary>
    </ResourceDictionary.ThemeDictionaries>

    <!-- Layout (theme-independent) -->
    <CornerRadius x:Key="RadiusPanel">10</CornerRadius>
    <CornerRadius x:Key="RadiusPanelLg">12</CornerRadius>
    <CornerRadius x:Key="RadiusCard">10</CornerRadius>
    <CornerRadius x:Key="RadiusInput">8</CornerRadius>
    <CornerRadius x:Key="RadiusCover">6</CornerRadius>
    <CornerRadius x:Key="RadiusBadge">4</CornerRadius>
    <CornerRadius x:Key="RadiusBrowser">8</CornerRadius>

    <Thickness x:Key="ThicknessPanelPadding">16</Thickness>
    <Thickness x:Key="ThicknessPanelPaddingLg">18</Thickness>
    <Thickness x:Key="ThicknessPanelPaddingDetail">20</Thickness>
    <Thickness x:Key="ThicknessWindowMargin">20</Thickness>
    <Thickness x:Key="ThicknessSectionGap">0,0,0,20</Thickness>

    <!-- Typography (overridden at runtime by UiFontScaleService) -->
    <x:Double x:Key="FontSizeBadge">10</x:Double>
    <x:Double x:Key="FontSizeListMeta">11</x:Double>
    <x:Double x:Key="FontSizeCaption">12</x:Double>
    <x:Double x:Key="FontSizeLabel">13</x:Double>
    <x:Double x:Key="FontSizeBody">14</x:Double>
    <x:Double x:Key="FontSizeSubtitle">16</x:Double>
    <x:Double x:Key="FontSizeIcon">16</x:Double>
    <x:Double x:Key="FontSizeTitle">18</x:Double>
    <x:Double x:Key="FontSizeHeadingMd">22</x:Double>
    <x:Double x:Key="FontSizeHeadingLg">24</x:Double>
    <x:Double x:Key="FontSizeHeadingXl">28</x:Double>

    <x:Double x:Key="LineHeightCaption">16</x:Double>
    <x:Double x:Key="LineHeightLabel">18</x:Double>
    <x:Double x:Key="LineHeightBody">20</x:Double>
    <x:Double x:Key="LineHeightBodyLoose">21</x:Double>
    <x:Double x:Key="LineHeightTitle">24</x:Double>
    <x:Double x:Key="LineHeightHeadingXl">34</x:Double>

</ResourceDictionary>
