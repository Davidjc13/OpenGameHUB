<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:OpenGameHUB.ViewModels"
        x:Class="OpenGameHUB.Views.EaManualInstallNoticeWindow"
        x:DataType="vm:EaManualInstallNoticeViewModel"
        Title="{Binding Strings.EaManualInstallNoticeTitle}"
        Width="480"
        Height="260"
        MinWidth="420"
        MinHeight="220"
        SizeToContent="Height"
        WindowStartupLocation="CenterOwner"
        Background="#10131A">

    <Grid Margin="24"
          RowDefinitions="*,Auto">
        <StackPanel Spacing="12">
            <TextBlock Text="{Binding Strings.EaManualInstallNoticeTitle}"
                       FontSize="22"
                       FontWeight="Bold"
                       Foreground="#F4F7FF"/>
            <TextBlock Text="{Binding GameTitle}"
                       FontSize="16"
                       FontWeight="SemiBold"
                       Foreground="#D7DFF1"
                       TextWrapping="Wrap"/>
            <TextBlock Text="{Binding Message}"
                       Foreground="#9AA6BF"
                       TextWrapping="Wrap"/>
        </StackPanel>

        <Button Grid.Row="1"
                Classes="primary"
                Content="{Binding Strings.EaManualInstallNoticeOk}"
                Command="{Binding CloseCommand}"
                HorizontalAlignment="Stretch"
                Margin="0,20,0,0"/>
    </Grid>
</Window>
