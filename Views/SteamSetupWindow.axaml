<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:OpenGameHUB.ViewModels"
        x:Class="OpenGameHUB.Views.SteamSetupWindow"
        x:DataType="vm:SteamSetupViewModel"
        Title="{Binding Strings.SteamSetupTitle}"
        Width="520"
        Height="540"
        MinWidth="480"
        MinHeight="480"
        WindowStartupLocation="CenterOwner"
        Classes="app-window">

    <Grid Margin="24"
          RowDefinitions="*,Auto">
        <ScrollViewer Grid.Row="0"
                      Classes="dialogScroll"
                      HorizontalScrollBarVisibility="Disabled"
                      VerticalScrollBarVisibility="Auto">
            <StackPanel Spacing="14">
                    <TextBlock Text="{Binding Strings.SteamSetupTitle}"
                               Classes="heading-md"/>
                    <TextBlock Text="{Binding Strings.SteamSetupDescription}"
                               Classes="text-secondary"
                               TextWrapping="Wrap"/>

                    <Border Classes="panel-card">
                        <StackPanel Spacing="10">
                            <TextBlock Text="{Binding Strings.SteamSetupStepAccount}"
                                       Classes="text-label"/>
                            <TextBlock Text="{Binding Strings.SteamSetupStepAccountHelp}"
                                       Classes="text-help"
                                       TextWrapping="Wrap"/>
                            <Button Content="{Binding Strings.SteamSetupDetectAccount}"
                                    Command="{Binding DetectSteamAccountCommand}"
                                    HorizontalAlignment="Left"/>
                            <TextBlock Text="{Binding DetectedAccountLabel}"
                                       Classes="text-secondary"
                                       TextWrapping="Wrap"
                                       IsVisible="{Binding HasDetectedAccount}"/>
                        </StackPanel>
                    </Border>

                    <Border Classes="panel-card">
                        <StackPanel Spacing="10">
                            <TextBlock Text="{Binding Strings.SteamSetupStepApiKey}"
                                       Classes="text-label"/>
                            <TextBlock Text="{Binding Strings.SteamSetupStepApiKeyHelp}"
                                       Classes="text-help"
                                       TextWrapping="Wrap"/>
                            <Button Content="{Binding Strings.SteamSetupSignInWithBrowser}"
                                    Command="{Binding SignInWithBrowserCommand}"
                                    HorizontalAlignment="Left"
                                    IsEnabled="{Binding CanSignInWithBrowser}"/>
                            <TextBox PlaceholderText="{Binding Strings.SteamApiKeyPlaceholder}"
                                     Text="{Binding SteamApiKey}"/>
                        </StackPanel>
                    </Border>

                    <TextBlock Text="{Binding StatusMessage}"
                               Classes="text-secondary"
                               TextWrapping="Wrap"/>
            </StackPanel>
        </ScrollViewer>

        <StackPanel Grid.Row="1"
                    Orientation="Horizontal"
                    Spacing="10"
                    HorizontalAlignment="Right"
                    Margin="0,16,0,0">
            <Button Content="{Binding Strings.Cancel}"
                    Command="{Binding CancelCommand}"/>
            <Button Classes="primary"
                    Content="{Binding Strings.SteamSetupTestAndSave}"
                    Command="{Binding TestAndSaveCommand}"
                    IsEnabled="{Binding !IsBusy}"/>
        </StackPanel>
    </Grid>
</Window>
