<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:OpenGameHUB.ViewModels"
        x:Class="OpenGameHUB.Views.SteamSetupWindow"
        x:DataType="vm:SteamSetupViewModel"
        Title="{Binding Strings.SteamSetupTitle}"
        Width="520"
        Height="520"
        MinHeight="480"
        WindowStartupLocation="CenterOwner"
        Background="#10131A">

    <ScrollViewer Margin="24">
        <StackPanel Spacing="14">
            <TextBlock Text="{Binding Strings.SteamSetupTitle}"
                       FontSize="22"
                       FontWeight="Bold"
                       Foreground="#F4F7FF"/>
            <TextBlock Text="{Binding Strings.SteamSetupDescription}"
                       Foreground="#9AA6BF"
                       TextWrapping="Wrap"/>

            <Border Background="#161B27"
                    CornerRadius="10"
                    Padding="14"
                    BorderBrush="#2B3448"
                    BorderThickness="1">
                <StackPanel Spacing="10">
                    <TextBlock Text="{Binding Strings.SteamSetupStepAccount}"
                               FontWeight="SemiBold"
                               Foreground="#D7DFF1"/>
                    <TextBlock Text="{Binding Strings.SteamSetupStepAccountHelp}"
                               Foreground="#7E8AA3"
                               FontSize="12"
                               TextWrapping="Wrap"/>
                    <Button Content="{Binding Strings.SteamSetupDetectAccount}"
                            Command="{Binding DetectSteamAccountCommand}"
                            HorizontalAlignment="Left"/>
                    <TextBlock Text="{Binding DetectedAccountLabel}"
                               Foreground="#9AA6BF"
                               TextWrapping="Wrap"
                               IsVisible="{Binding HasDetectedAccount}"/>
                </StackPanel>
            </Border>

            <Border Background="#161B27"
                    CornerRadius="10"
                    Padding="14"
                    BorderBrush="#2B3448"
                    BorderThickness="1">
                <StackPanel Spacing="10">
                    <TextBlock Text="{Binding Strings.SteamSetupStepApiKey}"
                               FontWeight="SemiBold"
                               Foreground="#D7DFF1"/>
                    <TextBlock Text="{Binding Strings.SteamSetupStepApiKeyHelp}"
                               Foreground="#7E8AA3"
                               FontSize="12"
                               TextWrapping="Wrap"/>
                    <Button Content="{Binding Strings.SteamSetupOpenApiKeyPage}"
                            Command="{Binding OpenApiKeyPageCommand}"
                            HorizontalAlignment="Left"/>
                    <TextBox PlaceholderText="{Binding Strings.SteamApiKeyPlaceholder}"
                             Text="{Binding SteamApiKey}"/>
                </StackPanel>
            </Border>

            <TextBlock Text="{Binding StatusMessage}"
                       Foreground="#9AA6BF"
                       TextWrapping="Wrap"/>

            <StackPanel Orientation="Horizontal"
                        Spacing="10"
                        HorizontalAlignment="Right"
                        Margin="0,8,0,0">
                <Button Content="{Binding Strings.Cancel}"
                        Command="{Binding CancelCommand}"/>
                <Button Classes="primary"
                        Content="{Binding Strings.SteamSetupTestAndSave}"
                        Command="{Binding TestAndSaveCommand}"
                        IsEnabled="{Binding !IsBusy}"/>
            </StackPanel>
        </StackPanel>
    </ScrollViewer>
</Window>
