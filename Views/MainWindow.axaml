<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:OpenGameHUB.ViewModels"
        xmlns:conv="using:OpenGameHUB.Converters"
        x:Class="OpenGameHUB.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Icon="/Assets/app.ico"
        Title="OpenGameHUB"
        Width="1280"
        Height="800"
        MinWidth="1000"
        MinHeight="640"
        Background="#10131A">

    <Window.Resources>
        <conv:PlatformBrushConverter x:Key="PlatformBrushConverter"/>
    </Window.Resources>

    <Grid RowDefinitions="Auto,Auto,*" Margin="24">
        <Grid Grid.Row="0" ColumnDefinitions="*,Auto,Auto">
            <StackPanel Spacing="6">
                <TextBlock Text="OpenGameHUB"
                           FontSize="32"
                           FontWeight="Bold"
                           Foreground="#F4F7FF"/>
                <TextBlock Text="{Binding Strings.AppSubtitle}"
                           Foreground="#9AA6BF"
                           FontSize="14"/>
            </StackPanel>
            <Button Grid.Column="1"
                    Margin="0,0,8,0"
                    VerticalAlignment="Center"
                    Content="{Binding Strings.Settings}"
                    Command="{Binding OpenSettingsCommand}"/>
            <Button Grid.Column="2"
                    Classes="primary"
                    VerticalAlignment="Center"
                    Content="{Binding Strings.RefreshLibrary}"
                    Command="{Binding RefreshLibraryCommand}"
                    IsEnabled="{Binding !IsRefreshing}"/>
        </Grid>

        <Grid Grid.Row="1" ColumnDefinitions="*,Auto" Margin="0,20,0,16">
            <TextBox PlaceholderText="{Binding Strings.SearchPlaceholder}"
                     Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                     CornerRadius="8"
                     Padding="12,10"
                     Background="#1A2030"
                     BorderBrush="#2B3448"/>
            <StackPanel Grid.Column="1"
                        Orientation="Horizontal"
                        Spacing="8"
                        Margin="16,0,0,0"
                        VerticalAlignment="Center">
                <ProgressBar Width="80"
                             Height="4"
                             IsIndeterminate="True"
                             IsVisible="{Binding IsRefreshing}"/>
                <TextBlock Foreground="#9AA6BF"
                           Text="{Binding StatusText}"
                           MaxWidth="360"
                           TextWrapping="Wrap"/>
            </StackPanel>
        </Grid>

        <Grid Grid.Row="2" ColumnDefinitions="220,*">
            <Border Background="#161B27"
                    CornerRadius="12"
                    Padding="14"
                    BorderBrush="#2B3448"
                    BorderThickness="1">
                <ScrollViewer>
                    <StackPanel Spacing="14">
                        <TextBlock Text="{Binding Strings.Platforms}"
                                   FontWeight="SemiBold"
                                   Foreground="#D7DFF1"/>
                        <ListBox ItemsSource="{Binding PlatformFilters}"
                                 SelectedItem="{Binding SelectedPlatformFilter}"
                                 Background="Transparent"
                                 BorderThickness="0">
                            <ListBox.ItemTemplate>
                                <DataTemplate x:DataType="vm:PlatformFilterItem">
                                    <TextBlock Text="{Binding Label}"
                                               Padding="8,6"
                                               Foreground="#C5CEE0"/>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>

                        <Separator Background="#2B3448"/>

                        <TextBlock Text="{Binding Strings.Sort}"
                                   FontWeight="SemiBold"
                                   Foreground="#D7DFF1"/>
                        <ComboBox ItemsSource="{Binding SortOptions}"
                                  SelectedItem="{Binding SelectedSortOption}"
                                  HorizontalAlignment="Stretch">
                            <ComboBox.ItemTemplate>
                                <DataTemplate x:DataType="vm:SortOptionItem">
                                    <TextBlock Text="{Binding Label}"/>
                                </DataTemplate>
                            </ComboBox.ItemTemplate>
                        </ComboBox>

                        <Separator Background="#2B3448"/>

                        <TextBlock Text="{Binding Strings.Filters}"
                                   FontWeight="SemiBold"
                                   Foreground="#D7DFF1"/>
                        <CheckBox Content="{Binding Strings.FavoritesOnly}"
                                  IsChecked="{Binding ShowFavoritesOnly}"
                                  Foreground="#C5CEE0"/>
                        <CheckBox Content="{Binding Strings.InstalledOnly}"
                                  IsChecked="{Binding ShowInstalledOnly}"
                                  Foreground="#C5CEE0"/>
                    </StackPanel>
                </ScrollViewer>
            </Border>

            <Grid Grid.Column="1" ColumnDefinitions="*,300" Margin="16,0,0,0">
                <Border Background="#161B27"
                        CornerRadius="12"
                        Padding="16"
                        BorderBrush="#2B3448"
                        BorderThickness="1">
                    <Grid RowDefinitions="*,Auto">
                        <ScrollViewer Grid.Row="0" HorizontalScrollBarVisibility="Disabled">
                            <ItemsControl ItemsSource="{Binding Games}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <WrapPanel Orientation="Horizontal"/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="vm:GameItemViewModel">
                                    <Border Width="180"
                                            Margin="0,0,12,12"
                                            CornerRadius="10"
                                            BorderThickness="2"
                                            Background="#1E2535"
                                            BorderBrush="{Binding IsSelected, Converter={x:Static conv:SelectionBorderConverter.Instance}}"
                                            ClipToBounds="True"
                                            PointerPressed="OnCardPressed"
                                            DoubleTapped="OnGameDoubleTapped">
                                        <Grid RowDefinitions="270,Auto,Auto,Auto">
                                            <Border Grid.Row="0"
                                                    ClipToBounds="True"
                                                    Background="#141A28">
                                                <Panel>
                                                    <Image Source="{Binding CoverImage}"
                                                           Stretch="UniformToFill"
                                                           HorizontalAlignment="Center"
                                                           VerticalAlignment="Center"
                                                           IsVisible="{Binding DisplayGridCover}"/>
                                                    <Border IsVisible="{Binding !DisplayGridCover}"
                                                            Background="{Binding Platform, Converter={StaticResource PlatformBrushConverter}}"
                                                            Opacity="0.28"/>
                                                    <TextBlock Text="{Binding Title}"
                                                               IsVisible="{Binding !DisplayGridCover}"
                                                               Margin="14"
                                                               VerticalAlignment="Center"
                                                               HorizontalAlignment="Center"
                                                               TextAlignment="Center"
                                                               TextWrapping="Wrap"
                                                               FontWeight="SemiBold"
                                                               FontSize="13"
                                                               Foreground="#F4F7FF"
                                                               MaxHeight="72"/>
                                                </Panel>
                                            </Border>

                                            <StackPanel Grid.Row="1" Margin="10,8,10,0" Spacing="3">
                                                <Border CornerRadius="4"
                                                        Padding="5,2"
                                                        HorizontalAlignment="Left"
                                                        Background="{Binding Platform, Converter={StaticResource PlatformBrushConverter}}">
                                                    <TextBlock Text="{Binding PlatformLabel}"
                                                               FontSize="10"
                                                               FontWeight="Bold"
                                                               Foreground="White"/>
                                                </Border>
                                                <TextBlock Text="{Binding Title}"
                                                           FontSize="13"
                                                           FontWeight="SemiBold"
                                                           Foreground="#F4F7FF"
                                                           TextWrapping="Wrap"
                                                           MaxHeight="36"
                                                           TextTrimming="CharacterEllipsis"/>
                                            </StackPanel>

                                            <TextBlock Grid.Row="2"
                                                       Margin="10,2,10,0"
                                                       Text="{Binding InstallStatus}"
                                                       FontSize="11"
                                                       Foreground="#8B97B0"/>

                                            <Button Grid.Row="3"
                                                    Margin="10,8,10,10"
                                                    Classes="primary"
                                                    HorizontalAlignment="Stretch"
                                                    Content="{Binding ActionLabel}"
                                                    Click="OnPlayClick"/>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                        </ScrollViewer>
                        <StackPanel Grid.Row="1"
                                    Orientation="Horizontal"
                                    HorizontalAlignment="Center"
                                    Spacing="12"
                                    Margin="0,12,0,0">
                            <Button Content="{Binding Strings.PreviousPage}"
                                    Command="{Binding PreviousPageCommand}"/>
                            <TextBlock VerticalAlignment="Center"
                                       Foreground="#9AA6BF"
                                       Text="{Binding GamesCountLabel}"/>
                            <Button Content="{Binding Strings.NextPage}"
                                    Command="{Binding NextPageCommand}"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <Border Grid.Column="1"
                        Margin="16,0,0,0"
                        Background="#161B27"
                        CornerRadius="12"
                        Padding="20"
                        BorderBrush="#2B3448"
                        BorderThickness="1">
                    <StackPanel Spacing="14">
                        <TextBlock Text="{Binding Strings.Detail}"
                                   FontSize="18"
                                   FontWeight="SemiBold"
                                   Foreground="#F4F7FF"/>

                        <Border Width="200"
                                Height="300"
                                HorizontalAlignment="Center"
                                CornerRadius="8"
                                ClipToBounds="True"
                                Background="#141A28">
                            <Image Source="{Binding SelectedGame.CoverImage}"
                                   Stretch="UniformToFill"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"
                                   IsVisible="{Binding SelectedGame.HasCover}"/>
                        </Border>

                        <TextBlock Text="{Binding SelectedGameTitle}"
                                   FontSize="17"
                                   FontWeight="SemiBold"
                                   Foreground="#F4F7FF"
                                   TextWrapping="Wrap"/>
                        <TextBlock Text="{Binding SelectedGame.InstallStatus, TargetNullValue=''}"
                                   Foreground="#9AA6BF"/>
                        <TextBlock Text="{Binding SelectedGame.InstallPath, TargetNullValue=''}"
                                   TextWrapping="Wrap"
                                   Foreground="#7E8AA3"
                                   FontSize="12"/>
                        <Button Classes="primary"
                                Content="{Binding SelectedGameActionLabel}"
                                HorizontalAlignment="Stretch"
                                Command="{Binding LaunchSelectedGameCommand}"/>
                        <Button Content="{Binding Strings.ToggleFavorite}"
                                HorizontalAlignment="Stretch"
                                Command="{Binding ToggleFavoriteCommand}"
                                CommandParameter="{Binding SelectedGame}"/>
                    </StackPanel>
                </Border>
            </Grid>
        </Grid>
    </Grid>
</Window>
