<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:OpenGameHUB.ViewModels"
        xmlns:controls="using:OpenGameHUB.Controls"
        x:Class="OpenGameHUB.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Icon="/Assets/app.ico"
        Title="OpenGameHUB"
        Width="1280"
        Height="800"
        MinWidth="1000"
        MinHeight="640"
        Classes="app-window">

    <Grid RowDefinitions="Auto,Auto,Auto,*" Margin="24">
        <Grid Grid.Row="0" ColumnDefinitions="*,Auto,Auto">
            <StackPanel Spacing="6">
                <TextBlock Text="OpenGameHUB"
                           Classes="heading-xl"/>
                <TextBlock Text="{Binding Strings.AppSubtitle}"
                           Classes="text-secondary"
                           FontSize="14"/>
                <TextBlock Text="{Binding Updates.AppVersionText}"
                           Classes="text-muted"
                           FontSize="12"/>
            </StackPanel>
            <Button Grid.Column="1"
                    Margin="0,0,8,0"
                    VerticalAlignment="Center"
                    Content="{Binding Strings.Settings}"
                    Command="{Binding OpenSettingsCommand}"/>
            <Button Grid.Column="2"
                    Classes="primary"
                    VerticalAlignment="Center"
                    Content="{Binding Strings.RefreshLibrary}"
                    Command="{Binding RefreshLibraryCommand}"
                    IsEnabled="{Binding !IsRefreshing}"/>
        </Grid>

        <Border Grid.Row="1"
                Classes="update-banner"
                Margin="0,0,0,16"
                IsVisible="{Binding Updates.IsAppUpdateBannerVisible}">
            <Grid ColumnDefinitions="*,Auto,Auto">
                <StackPanel Spacing="4" VerticalAlignment="Center">
                    <TextBlock Text="{Binding Updates.AppUpdateBannerText}"
                               Classes="text-banner"
                               TextWrapping="Wrap"/>
                    <ProgressBar Minimum="0"
                                 Maximum="100"
                                 Value="{Binding Updates.AppUpdateProgress}"
                                 IsVisible="{Binding Updates.IsAppUpdateInstalling}"
                                 Height="4"
                                 Margin="0,4,0,0"/>
                </StackPanel>
                <Button Grid.Column="1"
                        Classes="primary"
                        Margin="12,0,8,0"
                        VerticalAlignment="Center"
                        Content="{Binding Strings.AppUpdateInstallNow}"
                        Click="OnInstallAppUpdateClick"
                        IsEnabled="{Binding !Updates.IsAppUpdateInstalling}"/>
                <Button Grid.Column="2"
                        VerticalAlignment="Center"
                        Content="{Binding Strings.AppUpdateDismissLater}"
                        Command="{Binding Updates.DismissBannerCommand}"
                        IsEnabled="{Binding !Updates.IsAppUpdateInstalling}"/>
            </Grid>
        </Border>

        <Grid Grid.Row="2" ColumnDefinitions="*,Auto" Margin="0,0,0,16">
            <TextBox Name="SearchBox"
                     Classes="search-input"
                     PlaceholderText="{Binding Strings.SearchPlaceholder}"
                     Text="{Binding SearchText, Mode=TwoWay}"
                     TextChanged="OnSearchTextChanged"/>
            <StackPanel Grid.Column="1"
                        Orientation="Horizontal"
                        Spacing="8"
                        Margin="16,0,0,0"
                        VerticalAlignment="Center">
                <ProgressBar Width="80"
                             Height="4"
                             IsIndeterminate="True"
                             IsVisible="{Binding IsRefreshing}"/>
                <TextBlock Classes="text-secondary"
                           Text="{Binding StatusText}"
                           MaxWidth="360"
                           TextWrapping="Wrap"/>
            </StackPanel>
        </Grid>

        <Grid Grid.Row="3" ColumnDefinitions="220,*">
            <Border Classes="panel">
                <ScrollViewer>
                    <StackPanel Spacing="14">
                        <TextBlock Text="{Binding Strings.Platforms}"
                                   Classes="text-label"/>
                        <ListBox ItemsSource="{Binding PlatformFilters}"
                                 SelectedItem="{Binding SelectedPlatformFilter}"
                                 Classes="sidebar-list">
                            <ListBox.ItemTemplate>
                                <DataTemplate x:DataType="vm:PlatformFilterItem">
                                    <TextBlock Text="{Binding Label}"/>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>

                        <Separator Classes="divider"/>

                        <TextBlock Text="{Binding Strings.Sort}"
                                   Classes="text-label"/>
                        <ComboBox ItemsSource="{Binding SortOptions}"
                                  SelectedItem="{Binding SelectedSortOption}"
                                  HorizontalAlignment="Stretch">
                            <ComboBox.ItemTemplate>
                                <DataTemplate x:DataType="vm:SortOptionItem">
                                    <TextBlock Text="{Binding Label}"/>
                                </DataTemplate>
                            </ComboBox.ItemTemplate>
                        </ComboBox>

                        <Separator Classes="divider"/>

                        <TextBlock Text="{Binding Strings.Filters}"
                                   Classes="text-label"/>
                        <CheckBox Content="{Binding Strings.FavoritesOnly}"
                                  IsChecked="{Binding ShowFavoritesOnly}"
                                  Classes="sidebar"/>
                        <CheckBox Content="{Binding Strings.InstalledOnly}"
                                  IsChecked="{Binding ShowInstalledOnly}"
                                  Classes="sidebar"/>
                    </StackPanel>
                </ScrollViewer>
            </Border>

            <Grid Grid.Column="1" ColumnDefinitions="*,300" Margin="16,0,0,0">
                <Border Classes="panel-content">
                    <Grid RowDefinitions="Auto,*,Auto">
                        <StackPanel Grid.Row="0"
                                    Orientation="Horizontal"
                                    HorizontalAlignment="Right"
                                    Spacing="8"
                                    Margin="0,0,0,12">
                            <Button Content="{Binding Strings.ViewGrid}"
                                    Command="{Binding SetGridViewCommand}"
                                    Classes.primary="{Binding IsGridView}"/>
                            <Button Content="{Binding Strings.ViewList}"
                                    Command="{Binding SetListViewCommand}"
                                    Classes.primary="{Binding IsListView}"/>
                        </StackPanel>

                        <ScrollViewer Grid.Row="1" HorizontalScrollBarVisibility="Disabled">
                            <Panel>
                            <ItemsControl ItemsSource="{Binding Games}"
                                            IsVisible="{Binding !IsListView}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <WrapPanel Orientation="Horizontal"/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="vm:GameItemViewModel">
                                    <controls:GameGridCard/>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <ItemsControl ItemsSource="{Binding Games}"
                                      IsVisible="{Binding IsListView}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <StackPanel Spacing="8"/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="vm:GameItemViewModel">
                                    <controls:GameListCard/>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                            </Panel>
                        </ScrollViewer>
                        <StackPanel Grid.Row="2"
                                    Orientation="Horizontal"
                                    HorizontalAlignment="Center"
                                    Spacing="12"
                                    Margin="0,12,0,0">
                            <Button Content="{Binding Strings.PreviousPage}"
                                    Command="{Binding PreviousPageCommand}"/>
                            <TextBlock VerticalAlignment="Center"
                                       Classes="text-secondary"
                                       Text="{Binding GamesCountLabel}"/>
                            <Button Content="{Binding Strings.NextPage}"
                                    Command="{Binding NextPageCommand}"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <Border Grid.Column="1"
                        Classes="panel-detail"
                        Margin="16,0,0,0">
                    <Grid RowDefinitions="Auto,*">
                        <TextBlock Grid.Row="0"
                                   Text="{Binding Strings.Detail}"
                                   Classes="heading-panel"
                                   Margin="0,0,0,14"/>

                        <ScrollViewer Grid.Row="1"
                                      VerticalScrollBarVisibility="Auto"
                                      HorizontalScrollBarVisibility="Disabled">
                            <StackPanel Spacing="14">
                        <Border Width="200"
                                Height="300"
                                Classes="cover-frame-lg"
                                IsVisible="{Binding ShowDetailCover}">
                            <Image Source="{Binding SelectedGame.CoverImage}"
                                   Stretch="Uniform"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"
                                   IsVisible="{Binding SelectedGame.HasCover}"/>
                        </Border>

                        <TextBlock Text="{Binding SelectedGameTitle}"
                                   FontSize="17"
                                   FontWeight="SemiBold"
                                   Classes="text-primary"
                                   TextWrapping="Wrap"/>
                        <TextBlock Text="{Binding SelectedGame.InstallStatus, TargetNullValue=''}"
                                   Classes="text-secondary"/>
                        <TextBlock Text="{Binding SelectedGame.InstallPath, TargetNullValue=''}"
                                   TextWrapping="Wrap"
                                   Classes="text-tertiary"
                                   FontSize="12"/>
                        <Button Classes="primary"
                                Content="{Binding SelectedGameActionLabel}"
                                HorizontalAlignment="Stretch"
                                Command="{Binding LaunchSelectedGameCommand}"/>
                        <Button Content="{Binding Strings.ToggleFavorite}"
                                HorizontalAlignment="Stretch"
                                Command="{Binding ToggleFavoriteCommand}"
                                CommandParameter="{Binding SelectedGame}"/>
                        <Button Content="{Binding Strings.ChangeCover}"
                                HorizontalAlignment="Stretch"
                                Command="{Binding ChangeCustomCoverCommand}"/>
                        <Button Content="{Binding Strings.ResetCover}"
                                HorizontalAlignment="Stretch"
                                Command="{Binding ResetCustomCoverCommand}"
                                IsVisible="{Binding SelectedGameHasCustomCover}"/>
                            </StackPanel>
                        </ScrollViewer>
                    </Grid>
                </Border>
            </Grid>
        </Grid>
    </Grid>
</Window>
