<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:OpenGameHUB.ViewModels"
        x:Class="OpenGameHUB.Views.SteamApiKeyPromptWindow"
        x:DataType="vm:SteamApiKeyPromptViewModel"
        Title="{Binding Strings.SteamApiKeyPromptTitle}"
        Width="520"
        Height="540"
        MinWidth="480"
        MinHeight="480"
        WindowStartupLocation="CenterOwner"
        Background="#10131A">

    <Grid Margin="24"
          RowDefinitions="*,Auto">
        <ScrollViewer Grid.Row="0"
                      Classes="dialogScroll"
                      HorizontalScrollBarVisibility="Disabled"
                      VerticalScrollBarVisibility="Auto">
            <StackPanel Spacing="16">
                    <TextBlock Text="{Binding Strings.SteamApiKeyPromptTitle}"
                               FontSize="22"
                               FontWeight="Bold"
                               Foreground="#F4F7FF"/>
                    <TextBlock Text="{Binding Strings.SteamApiKeyPromptIntro}"
                               Foreground="#9AA6BF"
                               TextWrapping="Wrap"/>

                    <Border Background="#161B27"
                            CornerRadius="10"
                            Padding="14"
                            BorderBrush="#2B3448"
                            BorderThickness="1">
                        <StackPanel Spacing="6">
                            <TextBlock Text="{Binding Strings.SteamApiKeyPromptWhyTitle}"
                                       FontWeight="SemiBold"
                                       Foreground="#D7DFF1"/>
                            <TextBlock Text="{Binding Strings.SteamApiKeyPromptWhy}"
                                       Foreground="#7E8AA3"
                                       FontSize="12"
                                       TextWrapping="Wrap"/>
                        </StackPanel>
                    </Border>

                    <Border Background="#161B27"
                            CornerRadius="10"
                            Padding="14"
                            BorderBrush="#2B3448"
                            BorderThickness="1">
                        <StackPanel Spacing="6">
                            <TextBlock Text="{Binding Strings.SteamApiKeyPromptWithoutTitle}"
                                       FontWeight="SemiBold"
                                       Foreground="#D7DFF1"/>
                            <TextBlock Text="{Binding Strings.SteamApiKeyPromptWithout}"
                                       Foreground="#7E8AA3"
                                       FontSize="12"
                                       TextWrapping="Wrap"/>
                        </StackPanel>
                    </Border>
            </StackPanel>
        </ScrollViewer>

        <StackPanel Grid.Row="1"
                    Spacing="10"
                    Margin="0,20,0,0">
            <Button Classes="primary"
                    Content="{Binding Strings.SteamApiKeyPromptConfigure}"
                    Command="{Binding ConfigureCommand}"
                    HorizontalAlignment="Stretch"/>
            <Button Content="{Binding Strings.SteamApiKeyPromptContinue}"
                    Command="{Binding ContinueWithoutCommand}"
                    HorizontalAlignment="Stretch"/>
            <Button Content="{Binding Strings.SteamApiKeyPromptDontRemind}"
                    Command="{Binding DontRemindAgainCommand}"
                    HorizontalAlignment="Stretch"/>
        </StackPanel>
    </Grid>
</Window>
