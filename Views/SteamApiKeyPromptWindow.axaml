<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:OpenGameHUB.ViewModels"
        x:Class="OpenGameHUB.Views.SteamApiKeyPromptWindow"
        x:DataType="vm:SteamApiKeyPromptViewModel"
        Title="{Binding Strings.SteamApiKeyPromptTitle}"
        Width="520"
        Height="540"
        MinWidth="480"
        MinHeight="480"
        WindowStartupLocation="CenterOwner"
        Classes="app-window">

    <Grid Margin="24"
          RowDefinitions="*,Auto">
        <ScrollViewer Grid.Row="0"
                      Classes="dialogScroll"
                      HorizontalScrollBarVisibility="Disabled"
                      VerticalScrollBarVisibility="Auto">
            <StackPanel Spacing="16">
                    <TextBlock Text="{Binding Strings.SteamApiKeyPromptTitle}"
                               Classes="heading-md"/>
                    <TextBlock Text="{Binding Strings.SteamApiKeyPromptIntro}"
                               Classes="text-secondary"
                               TextWrapping="Wrap"/>

                    <Border Classes="panel-card">
                        <StackPanel Spacing="6">
                            <TextBlock Text="{Binding Strings.SteamApiKeyPromptWhyTitle}"
                                       Classes="text-label"/>
                            <TextBlock Text="{Binding Strings.SteamApiKeyPromptWhy}"
                                       Classes="text-help"
                                       TextWrapping="Wrap"/>
                        </StackPanel>
                    </Border>

                    <Border Classes="panel-card">
                        <StackPanel Spacing="6">
                            <TextBlock Text="{Binding Strings.SteamApiKeyPromptWithoutTitle}"
                                       Classes="text-label"/>
                            <TextBlock Text="{Binding Strings.SteamApiKeyPromptWithout}"
                                       Classes="text-help"
                                       TextWrapping="Wrap"/>
                        </StackPanel>
                    </Border>
            </StackPanel>
        </ScrollViewer>

        <StackPanel Grid.Row="1"
                    Spacing="10"
                    Margin="0,20,0,0">
            <Button Classes="primary"
                    Content="{Binding Strings.SteamApiKeyPromptConfigure}"
                    Command="{Binding ConfigureCommand}"
                    HorizontalAlignment="Stretch"/>
            <Button Content="{Binding Strings.SteamApiKeyPromptContinue}"
                    Command="{Binding ContinueWithoutCommand}"
                    HorizontalAlignment="Stretch"/>
            <Button Content="{Binding Strings.SteamApiKeyPromptDontRemind}"
                    Command="{Binding DontRemindAgainCommand}"
                    HorizontalAlignment="Stretch"/>
        </StackPanel>
    </Grid>
</Window>
