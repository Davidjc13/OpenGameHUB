<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:OpenGameHUB.ViewModels"
        x:Class="OpenGameHUB.Views.CollectionNameDialog"
        x:DataType="vm:CollectionNameDialogViewModel"
        Title="{Binding Title}"
        Width="420"
        Height="220"
        MinWidth="360"
        WindowStartupLocation="CenterOwner"
        Classes="app-window">
    <Grid Margin="24" RowDefinitions="Auto,*,Auto">
        <TextBlock Grid.Row="0"
                   Text="{Binding Prompt}"
                   Classes="text-secondary"
                   TextWrapping="Wrap"/>

        <TextBox Grid.Row="1"
                 Margin="0,16,0,16"
                 Text="{Binding Name}"
                 PlaceholderText="{Binding Strings.CollectionNamePlaceholder}"/>

        <StackPanel Grid.Row="2"
                    Orientation="Horizontal"
                    Spacing="10"
                    HorizontalAlignment="Right">
            <Button Content="{Binding Strings.Cancel}"
                    Command="{Binding CancelCommand}"
                    CommandParameter="{Binding RelativeSource={RelativeSource AncestorType=Window}}"/>
            <Button Classes="primary"
                    Content="{Binding Strings.Save}"
                    Command="{Binding ConfirmCommand}"
                    CommandParameter="{Binding RelativeSource={RelativeSource AncestorType=Window}}"/>
        </StackPanel>
    </Grid>
</Window>
