<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:OpenGameHUB.ViewModels"
        xmlns:browser="using:OpenGameHUB.Views.EmbeddedBrowser"
        x:Class="OpenGameHUB.Views.EmbeddedBrowserWindow"
        x:DataType="vm:EmbeddedBrowserViewModel"
        Title="{Binding WindowTitle}"
        Width="920"
        Height="720"
        MinWidth="720"
        MinHeight="560"
        WindowStartupLocation="CenterOwner"
        Background="#10131A">
    <Grid Margin="16" RowDefinitions="Auto,*,Auto,Auto">
        <StackPanel Grid.Row="0" Spacing="6" Margin="0,0,0,12">
            <TextBlock Text="{Binding WindowTitle}"
                       FontSize="18"
                       FontWeight="SemiBold"
                       Foreground="#F4F7FF"/>
            <TextBlock Text="{Binding IntroText}"
                       Foreground="#9AA6BF"
                       TextWrapping="Wrap"/>
        </StackPanel>

        <Border Grid.Row="1"
                Background="#161B27"
                CornerRadius="8"
                BorderBrush="#2B3448"
                BorderThickness="1"
                ClipToBounds="True">
            <browser:WebView2Host x:Name="BrowserHost"/>
        </Border>

        <TextBlock Grid.Row="2"
                   Margin="0,10,0,0"
                   Text="{Binding StatusMessage}"
                   Foreground="#9AA6BF"
                   TextWrapping="Wrap"/>

        <StackPanel Grid.Row="3"
                    Orientation="Horizontal"
                    Spacing="10"
                    HorizontalAlignment="Right"
                    Margin="0,12,0,0">
            <Button Content="{Binding Strings.Cancel}"
                    Command="{Binding CancelCommand}"/>
        </StackPanel>
    </Grid>
</Window>
