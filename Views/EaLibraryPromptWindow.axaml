<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:OpenGameHUB.ViewModels"
        x:Class="OpenGameHUB.Views.EaLibraryPromptWindow"
        x:DataType="vm:EaLibraryPromptViewModel"
        Title="{Binding Strings.EaLibraryPromptTitle}"
        Width="520"
        Height="560"
        MinWidth="480"
        MinHeight="500"
        WindowStartupLocation="CenterOwner"
        Classes="app-window">

    <Grid Margin="24"
          RowDefinitions="*,Auto">
        <ScrollViewer Grid.Row="0"
                      Classes="dialogScroll"
                      HorizontalScrollBarVisibility="Disabled"
                      VerticalScrollBarVisibility="Auto">
            <StackPanel Spacing="16">
                <TextBlock Text="{Binding Strings.EaLibraryPromptTitle}"
                           Classes="heading-md"/>
                <TextBlock Text="{Binding Strings.EaLibraryPromptIntro}"
                           Classes="text-secondary"
                           TextWrapping="Wrap"/>

                <Border Classes="panel-card">
                    <StackPanel Spacing="6">
                        <TextBlock Text="{Binding Strings.EaLibraryPromptWhyTitle}"
                                   Classes="text-label"/>
                        <TextBlock Text="{Binding Strings.EaLibraryPromptWhy}"
                                   Classes="text-help"
                                   TextWrapping="Wrap"/>
                    </StackPanel>
                </Border>

                <Border Classes="panel-card"
                        IsVisible="{Binding IsLogFallback}">
                    <StackPanel Spacing="6">
                        <TextBlock Text="{Binding Strings.EaLibraryPromptFallbackTitle}"
                                   Classes="text-label"/>
                        <TextBlock Text="{Binding Strings.EaLibraryPromptFallback}"
                                   Classes="text-help"
                                   TextWrapping="Wrap"/>
                    </StackPanel>
                </Border>

                <Border Classes="panel-card"
                        IsVisible="{Binding !IsLogFallback}">
                    <StackPanel Spacing="6">
                        <TextBlock Text="{Binding Strings.EaLibraryPromptRepairTitle}"
                                   Classes="text-label"/>
                        <TextBlock Text="{Binding Strings.EaLibraryPromptRepair}"
                                   Classes="text-help"
                                   TextWrapping="Wrap"/>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>

        <StackPanel Grid.Row="1"
                    Spacing="10"
                    Margin="0,20,0,0">
            <Button Classes="primary"
                    Content="{Binding Strings.EaLibraryPromptOpenEaApp}"
                    Command="{Binding OpenEaAppCommand}"
                    HorizontalAlignment="Stretch"/>
            <Button Content="{Binding Strings.EaLibraryPromptContinue}"
                    Command="{Binding ContinueCommand}"
                    HorizontalAlignment="Stretch"/>
            <Button Content="{Binding Strings.EaLibraryPromptDontRemind}"
                    Command="{Binding DontRemindAgainCommand}"
                    HorizontalAlignment="Stretch"/>
        </StackPanel>
    </Grid>
</Window>
