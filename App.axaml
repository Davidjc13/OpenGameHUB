<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="OpenGameHUB.App">

    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceInclude Source="avares://OpenGameHUB/Styles/Tokens.axaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Application.Resources>

    <Application.Styles>
        <FluentTheme />
        <StyleInclude Source="avares://OpenGameHUB/Styles/Typography.axaml"/>
        <StyleInclude Source="avares://OpenGameHUB/Styles/Layout.axaml"/>
        <StyleInclude Source="avares://OpenGameHUB/Styles/Controls.axaml"/>
        <StyleInclude Source="avares://OpenGameHUB/Styles/Components.axaml"/>
    </Application.Styles>
</Application>
